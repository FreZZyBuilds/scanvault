<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#0a0a0f">
<meta name="description" content="ScanVault - QR Code Scanner">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>ScanVault</title>
<link rel="manifest" href="manifest.json">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0a0f;--surface:#111118;--surface2:#18181f;--border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.12);--accent:#7cfc8a;--text:#e8e8f0;--muted:#6b6b7e;--red:#ff4f4f;--mono:'DM Mono',monospace;--sans:'Syne',sans-serif}*{box-sizing:border-box;margin:0;padding:0}body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;display:flex;flex-direction:column;align-items:center}body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(124,252,138,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(124,252,138,0.02) 1px,transparent 1px);background-size:48px 48px;pointer-events:none;z-index:0}.shell{position:relative;z-index:1;width:100%;max-width:480px;min-height:100vh;display:flex;flex-direction:column;padding:0 0 96px}@media(min-width:600px){.shell{max-width:600px;padding:0 20px 96px}}@media(min-width:768px){.shell{max-width:750px;padding:0 40px 96px}}@media(min-width:1024px){.shell{max-width:900px;padding:0 60px 96px}}@media(min-width:1440px){.shell{max-width:1000px;padding:0 80px 96px}}header{padding:32px 24px 20px;display:flex;align-items:center;justify-content:space-between}@media(min-width:600px){header{padding:40px 24px 20px}}@media(min-width:1024px){header{padding:56px 24px 28px}}.wordmark{font-size:22px;font-weight:800;color:var(--text);display:flex;align-items:center;gap:8px}@media(min-width:1024px){.wordmark{font-size:28px}}.wordmark-dot{width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:0 0 10px var(--accent);animation:pulse 2s infinite}@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.8)}}.scan-count{font-family:var(--mono);font-size:12px;color:var(--muted);background:var(--surface);border:1px solid var(--border);padding:4px 10px;border-radius:20px}.scan-count span{color:var(--accent)}.tabs{display:flex;margin:0 24px 24px;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:4px;gap:2px}.tab{flex:1;padding:8px 0;border:none;background:transparent;color:var(--muted);font-family:var(--sans);font-size:13px;font-weight:600;cursor:pointer;border-radius:9px;transition:all 0.2s}.tab.active{background:var(--surface2);color:var(--text);border:1px solid var(--border2)}.screen{display:none;flex-direction:column;gap:16px;padding:0 24px}.screen.active{display:flex;animation:fadein 0.25s ease}@keyframes fadein{from{opacity:0;transform:translateY(6px)}to{opacity:1}}.hero-card{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:32px 24px;display:flex;flex-direction:column;align-items:center;gap:20px}.qr-icon{width:72px;height:72px;display:grid;grid-template-columns:repeat(3,1fr);gap:5px;padding:12px;background:var(--surface2);border:1px solid var(--border2);border-radius:14px}.qr-cell{background:var(--accent);border-radius:3px}.qr-cell.empty{background:transparent}.hero-title{font-size:18px;font-weight:700;text-align:center}@media(min-width:600px){.hero-title{font-size:24px}}@media(min-width:1024px){.hero-title{font-size:28px}}.hero-sub{font-size:13px;color:var(--muted);text-align:center;line-height:1.6;font-family:var(--mono)}.btn-primary{width:100%;padding:16px;background:var(--accent);color:#0a0f0a;font-family:var(--sans);font-size:15px;font-weight:700;border:none;border-radius:14px;cursor:pointer;transition:all 0.15s;display:flex;align-items:center;justify-content:center;gap:8px}@media(min-width:600px){.btn-primary{font-size:16px;padding:18px}}.btn-primary:hover{background:#a0ffa8;transform:translateY(-1px)}.btn-secondary{width:100%;padding:15px;background:transparent;color:var(--text);font-family:var(--sans);font-size:15px;font-weight:600;border:1px solid var(--border2);border-radius:14px;cursor:pointer;transition:all 0.15s;display:flex;align-items:center;justify-content:center;gap:8px}.btn-secondary:hover{background:var(--surface2);border-color:var(--accent);color:var(--accent)}.btn-danger{padding:10px 16px;background:rgba(255,79,79,0.08);color:var(--red);font-family:var(--sans);font-size:13px;font-weight:600;border:1px solid rgba(255,79,79,0.2);border-radius:10px;cursor:pointer}.scanner-viewport{position:relative;width:100%;aspect-ratio:1;border-radius:20px;overflow:hidden;background:#000;border:1px solid var(--border2)}.scanner-viewport video{width:100%;height:100%;object-fit:cover}.scan-overlay{position:absolute;inset:0;display:flex;align-items:center;justify-content:center}.scan-frame{position:relative;width:280px;aspect-ratio:1;border:2px solid var(--accent);border-radius:20px}.scan-corner-br,.scan-corner-bl{position:absolute;width:40px;height:40px;border:2px solid var(--accent)}.scan-corner-br{bottom:-2px;right:-2px;border-top:none;border-left:none;border-radius:0 0 18px 0}.scan-corner-bl{bottom:-2px;left:-2px;border-top:none;border-right:none;border-radius:0 0 0 18px}.scan-line{position:absolute;top:50%;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--accent),transparent);animation:scan 2s infinite}@keyframes scan{0%,100%{transform:translateY(-100px)}50%{transform:translateY(100px)}}.scanner-idle{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;background:rgba(0,0,0,0.3)}.scanner-result{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:20px;display:none}.scanner-result.visible{display:block}.result-label{font-size:12px;color:var(--muted);margin-bottom:8px;text-transform:uppercase}.result-7{font-family:var(--mono);font-size:24px;font-weight:700;color:var(--accent);margin-bottom:12px}.stats-strip{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}@media(min-width:1024px){.stats-strip{gap:16px}}.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px 12px;display:flex;flex-direction:column;gap:4px}@media(min-width:1024px){.stat-card{padding:20px 16px}}.stat-val{font-family:var(--mono);font-size:22px;font-weight:500;color:var(--accent)}@media(min-width:1024px){.stat-val{font-size:28px}}.stat-lbl{font-family:var(--mono);font-size:10px;color:var(--muted)}.scans-list{display:flex;flex-direction:column;gap:12px}.scan-item{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:14px;display:flex;align-items:center;justify-content:space-between}.scan-code{font-family:var(--mono);font-size:16px;font-weight:700;color:var(--accent)}.copy-one{padding:6px 12px;background:var(--surface2);border:1px solid var(--border2);color:var(--text);font-family:var(--sans);font-size:12px;font-weight:600;border-radius:8px;cursor:pointer}.copy-one:hover{background:var(--accent);color:#0a0f0a}.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;padding:40px 20px;text-align:center;color:var(--muted)}.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--accent);color:#0a0f0a;font-family:var(--sans);font-size:14px;font-weight:700;padding:12px 24px;border-radius:40px;transition:transform 0.3s;z-index:100;white-space:nowrap}.toast.show{transform:translateX(-50%) translateY(0)}.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);z-index:2000;align-items:flex-end}.modal-overlay.show{display:flex}.modal-sheet{width:100%;background:var(--surface);border:1px solid var(--border2);border-radius:24px 24px 0 0;padding:24px;display:flex;flex-direction:column;gap:12px;animation:slideup 0.3s ease}@keyframes slideup{from{transform:translateY(100%)}to{transform:translateY(0)}}.modal-title{font-size:16px;font-weight:700;margin-bottom:8px}.modal-option{padding:14px 16px;background:var(--surface2);border:none;border-radius:12px;color:var(--text);font-family:var(--sans);font-size:14px;font-weight:600;cursor:pointer;transition:all 0.15s;display:flex;align-items:center;gap:10px}.modal-option:hover{background:rgba(124,252,138,0.1);color:var(--accent)}.modal-cancel{padding:14px;background:transparent;border:1px solid var(--border2);border-radius:12px;color:var(--muted);font-family:var(--sans);font-size:14px;font-weight:600;cursor:pointer;margin-top:8px}.welcome-overlay{display:none;position:fixed;inset:0;background:linear-gradient(135deg,rgba(10,10,15,0.95) 0%,rgba(17,17,24,0.95) 100%);z-index:3000;align-items:center;justify-content:center}.welcome-overlay.show{display:flex}.welcome-content{width:90%;max-width:500px;background:var(--surface);border:1px solid var(--border2);border-radius:24px;padding:32px 24px;display:flex;flex-direction:column;gap:24px;animation:fadeup 0.4s ease}@keyframes fadeup{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}.welcome-icon{font-size:64px;text-align:center}.welcome-title{font-size:28px;font-weight:800;text-align:center}.welcome-features{display:flex;flex-direction:column;gap:12px}.welcome-feature{display:flex;gap:12px;align-items:flex-start;padding:12px;background:var(--surface2);border-radius:12px;border:1px solid var(--border)}.welcome-feature-icon{font-size:20px;min-width:24px}.welcome-feature-text{font-size:13px;color:var(--text);line-height:1.5}.welcome-feature-title{font-weight:700;color:var(--accent);margin-bottom:2px}.welcome-btn-start{width:100%;padding:14px;background:var(--accent);color:#0a0f0a;border:none;border-radius:12px;font-family:var(--sans);font-size:15px;font-weight:700;cursor:pointer;transition:all 0.15s;margin-top:8px}.welcome-btn-start:hover{background:#a0ffa8}
</style>
</head>
<body>
<div class="shell">
<header>
<div class="wordmark"><span>ScanVault</span><div class="wordmark-dot"></div></div>
<div class="scan-count"><span id="total-count">0</span> <span>Codes</span></div>
</header>
<div class="tabs">
<button class="tab active" onclick="switchTab('home')">Home</button>
<button class="tab" onclick="switchTab('scanner')">Scanner</button>
<button class="tab" onclick="switchTab('history')">History</button>
</div>
<div class="screen active" id="screen-home">
<div class="hero-card">
<div class="qr-icon"><div class="qr-cell"></div><div class="qr-cell"></div><div class="qr-cell"></div><div class="qr-cell"></div><div class="qr-cell empty"></div><div class="qr-cell"></div><div class="qr-cell"></div><div class="qr-cell"></div><div class="qr-cell"></div></div>
<div class="hero-title">Welcome to ScanVault</div>
<div class="hero-sub">Secure QR Code Management with Local Storage</div>
</div>
<button class="btn-primary" onclick="switchTab('scanner')"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 7V5a2 2 0 0 1 2-2h2M17 3h2a2 2 0 0 1 2 2v2M21 17v2a2 2 0 0 1-2 2h-2M7 21H5a2 2 0 0 1-2-2v-2M7 7h10v10H7z"/></svg>Scan Code</button>
<button class="btn-secondary" onclick="copyAll()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>Copy All QR Codes</button>
<div style="padding:20px 0">
<div class="stats-strip">
<div class="stat-card"><div class="stat-val" id="stat-total">0</div><div class="stat-lbl">TOTAL</div></div>
<div class="stat-card"><div class="stat-val" id="stat-today">0</div><div class="stat-lbl">TODAY</div></div>
<div class="stat-card"><div class="stat-val">v3.2</div><div class="stat-lbl">VERSION</div></div>
</div>
</div>
<div style="background:var(--surface2);border:1px solid var(--border2);border-radius:16px;padding:16px;display:flex;flex-direction:column;gap:12px">
<div style="font-size:14px;font-weight:700;color:var(--accent);display:flex;align-items:center;gap:8px">
<span>📱 Install as App</span>
</div>
<div style="font-size:13px;color:var(--muted);line-height:1.6;font-family:var(--mono)">
<div style="margin-bottom:8px"><strong style="color:var(--text)">iPhone:</strong> Share → "Add to Home Screen"</div>
<div><strong style="color:var(--text)">Android:</strong> Menu (⋮) → "Install App"</div>
</div>
</div>
</div>
<div class="screen" id="screen-scanner">
<div class="scanner-viewport">
<video id="video" autoplay playsinline muted></video>
<div class="scan-overlay" id="scan-overlay" style="display:none">
<div class="scan-frame"><div class="scan-corner-br"></div><div class="scan-corner-bl"></div><div class="scan-line"></div></div>
</div>
<div class="scanner-idle" id="scanner-idle"><div style="font-size:48px">📷</div><p>Start Camera to Scan QR Codes</p></div>
</div>
<div class="scanner-result" id="scan-result">
<div class="result-label">Last Scan</div>
<div class="result-7" id="result-7">-------</div>
<div style="height:1px;background:var(--border);margin:8px 0"></div>
<div class="result-label">Full Code</div>
<div style="font-family:var(--mono);font-size:12px;color:var(--text);word-break:break-all" id="result-full">—</div>
</div>
<button class="btn-primary" id="start-btn" onclick="startScanner()"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor"/></svg>Start Camera</button>
<button class="btn-secondary" id="stop-btn" onclick="stopScanner()" style="display:none">Stop Camera</button>
<div style="display:flex;gap:8px;align-items:center"><div style="flex:1;height:1px;background:var(--border)"></div><span style="font-family:var(--mono);font-size:11px;color:var(--muted)">or manual</span><div style="flex:1;height:1px;background:var(--border)"></div></div>
<div style="display:flex;gap:8px">
<input id="manual-input" type="text" placeholder="Enter QR code manually" style="flex:1;background:var(--surface);border:1px solid var(--border2);color:var(--text);border-radius:12px;padding:12px 14px;font-family:var(--mono);font-size:13px;outline:none" onkeydown="if(event.key==='Enter')manualScan()">
<button class="btn-primary" style="width:auto;padding:12px 18px" onclick="manualScan()">→</button>
</div>
</div>
<div class="screen" id="screen-history">
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
<span style="font-size:15px;font-weight:700">Saved Codes</span>
<button class="btn-danger" onclick="clearAll()">Delete All</button>
</div>
<button class="btn-secondary" onclick="copyAll()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>Copy All QR Codes</button>
<button class="btn-secondary" onclick="showExportModal()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="8 17 12 21 16 17"></polyline><line x1="12" y1="12" x2="12" y2="21"></line><path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"/></svg>Export Data</button>
<div class="scans-list" id="scans-list"><div class="empty-state"><div style="font-size:48px;opacity:0.5">◫</div><div>No scans yet. Start scanning to begin.</div></div></div>
</div>
</div>
<div class="modal-overlay" id="export-modal">
<div class="modal-sheet">
<div class="modal-title">📥 Export Data</div>
<button class="modal-option" onclick="exportData('json')"><span>{ }</span><span>JSON</span></button>
<button class="modal-option" onclick="exportData('csv')"><span>📊</span><span>CSV</span></button>
<button class="modal-option" onclick="exportData('pdf')"><span>📄</span><span>PDF</span></button>
<button class="modal-option" onclick="exportData('excel')"><span>📈</span><span>Excel</span></button>
<button class="modal-option" onclick="exportData('copy')"><span>📋</span><span>Copy</span></button>
<button class="modal-cancel" onclick="closeExportModal()">Cancel</button>
</div>
</div>

<div class="welcome-overlay" id="welcome-overlay">
  <div class="welcome-content">
    <div class="welcome-icon">📱</div>
    <div class="welcome-title">Welcome to ScanVault</div>
    
    <div class="welcome-features">
      <div class="welcome-feature">
        <div class="welcome-feature-icon">📷</div>
        <div>
          <div class="welcome-feature-title">Scan QR Codes</div>
          <div class="welcome-feature-text">Use your camera to scan and save QR codes easily</div>
        </div>
      </div>
      
      <div class="welcome-feature">
        <div class="welcome-feature-icon">💾</div>
        <div>
          <div class="welcome-feature-title">Securely Local</div>
          <div class="welcome-feature-text">All your data stays on your device - no cloud, no transfers</div>
        </div>
      </div>
      
      <div class="welcome-feature">
        <div class="welcome-feature-icon">📊</div>
        <div>
          <div class="welcome-feature-title">Manage & Export</div>
          <div class="welcome-feature-text">Copy, export or delete your QR code collection anytime</div>
        </div>
      </div>
      
      <div class="welcome-feature">
        <div class="welcome-feature-icon">🌍</div>
        <div>
          <div class="welcome-feature-title">Always Available</div>
          <div class="welcome-feature-text">Works offline and as a native app on your device</div>
        </div>
      </div>
    </div>
    
    <button class="welcome-btn-start" onclick="closeWelcome()">Get Started</button>
  </div>
</div>

<div class="toast" id="toast"></div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.min.js"></script>
<script>
let scans=JSON.parse(localStorage.getItem('scanvault')||'[]');let stream=null;let scanning=false;let lastScanTime=0;
function showWelcome(){const hasSeenWelcome=localStorage.getItem('scanvault-welcome-seen');if(!hasSeenWelcome){document.getElementById('welcome-overlay').classList.add('show');}}
function closeWelcome(){localStorage.setItem('scanvault-welcome-seen','true');document.getElementById('welcome-overlay').classList.remove('show');}
function switchTab(name){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));document.getElementById('screen-'+name).classList.add('active');const tabs=document.querySelectorAll('.tab');tabs[['home','scanner','history'].indexOf(name)].classList.add('active');if(name==='history')renderList();if(name!=='scanner')stopScanner();updateCounts();}
function formatLast7(raw){const last7=raw.slice(-7).padStart(7,'·');return last7.substring(0,3)+'-'+last7.substring(3,6);}
async function startScanner(){try{stream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment'},audio:false});const video=document.getElementById('video');video.srcObject=stream;document.getElementById('scanner-idle').style.display='none';document.getElementById('scan-overlay').style.display='flex';document.getElementById('start-btn').style.display='none';document.getElementById('stop-btn').style.display='flex';scanning=true;requestAnimationFrame(scanFrame);showToast('✓ Camera activated');}catch(e){showToast('❌ Camera: '+e.name);}}
function stopScanner(){scanning=false;if(stream){stream.getTracks().forEach(t=>t.stop());stream=null;}const video=document.getElementById('video');video.srcObject=null;document.getElementById('scanner-idle').style.display='flex';document.getElementById('scan-overlay').style.display='none';document.getElementById('start-btn').style.display='flex';document.getElementById('stop-btn').style.display='none';}
function scanFrame(){if(!scanning)return;const video=document.getElementById('video');if(video.readyState===video.HAVE_ENOUGH_DATA){const canvas=document.createElement('canvas');canvas.width=video.videoWidth;canvas.height=video.videoHeight;const ctx=canvas.getContext('2d');ctx.drawImage(video,0,0);if('BarcodeDetector' in window){new BarcodeDetector({formats:['qr_code']}).detect(canvas).then(barcodes=>{if(barcodes.length>0){const now=Date.now();if(now-lastScanTime>2000){lastScanTime=now;processScan(barcodes[0].rawValue);}}}).catch(()=>{});}}requestAnimationFrame(scanFrame);}
function processScan(raw){const last7=formatLast7(raw);scans.unshift({raw,last7,ts:new Date().toISOString()});save();updateCounts();document.getElementById('result-7').textContent=last7;document.getElementById('result-full').textContent=raw;document.getElementById('scan-result').classList.add('visible');showToast('✓ Saved: '+last7);}
function manualScan(){const inp=document.getElementById('manual-input');const val=inp.value.trim();if(!val)return;processScan(val);inp.value='';}
function renderList(){const list=document.getElementById('scans-list');if(scans.length===0){list.innerHTML='<div class="empty-state"><div style="font-size:48px;opacity:0.5">◫</div><div>No scans yet</div></div>';return;}list.innerHTML=scans.map((s,i)=>{const d=new Date(s.ts);const dateStr=d.toLocaleDateString('en-US')+' '+d.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});return '<div class="scan-item"><div><div class="scan-code">'+s.last7+'</div><div style="font-size:11px;color:var(--muted);margin-top:4px">'+dateStr+'</div></div><button class="copy-one" onclick="copySingle('+i+')">Copy</button></div>'}).join('');}
function copySingle(i){navigator.clipboard.writeText(scans[i].last7).then(()=>{showToast('✓ '+scans[i].last7);});}
function copyAll(){if(scans.length===0)return;const all=scans.map(s=>s.last7).join('\n');navigator.clipboard.writeText(all).then(()=>{showToast('✓ '+scans.length+' codes copied');});}
function clearAll(){if(scans.length===0)return;if(confirm('Delete all '+scans.length+' scans?')){scans=[];save();renderList();updateCounts();showToast('History deleted');}}
function showExportModal(){if(scans.length===0)return;document.getElementById('export-modal').classList.add('show');}
function closeExportModal(){document.getElementById('export-modal').classList.remove('show');}
function exportData(format){if(scans.length===0)return;if(format==='json'){const data=scans.map(s=>({last7:s.last7,ts:s.ts}));downloadFile(JSON.stringify(data,null,2),'scanvault.json','application/json');showToast('✓ JSON exported');}else if(format==='csv'){let csv='Last7,Date\n';scans.forEach(s=>{const d=new Date(s.ts);csv+=s.last7+','+d.toLocaleDateString()+'\n';});downloadFile(csv,'scanvault.csv','text/csv');showToast('✓ CSV exported');}else if(format==='copy'){const text=scans.map(s=>s.last7).join('\n');navigator.clipboard.writeText(text).then(()=>{showToast('✓ Copied');closeExportModal();});}closeExportModal();}
function downloadFile(content,filename,type){const blob=new Blob([content],{type});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download=filename;document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(url);}
function save(){localStorage.setItem('scanvault',JSON.stringify(scans));}
function updateCounts(){const total=scans.length;const today=scans.filter(s=>{const d=new Date(s.ts);const now=new Date();return d.getDate()===now.getDate()&&d.getMonth()===now.getMonth()}).length;document.getElementById('total-count').textContent=total;document.getElementById('stat-total').textContent=total;document.getElementById('stat-today').textContent=today;}
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2200);}
document.getElementById('export-modal').addEventListener('click',e=>{if(e.target.id==='export-modal')closeExportModal();});
if('serviceWorker' in navigator){navigator.serviceWorker.register('sw.js').catch(()=>{});}
updateCounts();
showWelcome();
switchTab('home');
</script>
</body>
</html>
